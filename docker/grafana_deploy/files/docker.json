  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1,
        "query": "prometheus"
      },
      {
        "name": "container",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(docker_container_cpu_usage_percent, container_name)",
        "query": {
          "query": "label_values(docker_container_cpu_usage_percent, container_name)",
          "refId": "StandardVariableQuery"
        },
        "label": "Container",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1,
        "hide": 0
