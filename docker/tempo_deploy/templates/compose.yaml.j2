---
services:
  {{ APP }}:
    image: {{ IMAGE_NAME }}:{{ IMAGE_TAG }}
    container_name: {{ APP }}
    hostname: {{ APP }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - TZ=Europe/Stockholm
    command: ["-config.file=/etc/{{ APP }}.yaml"]
    ports:
      - {{ PORT_NUMBER1 }}:{{ PORT_NUMBER1 }}/tcp
      - {{ PORT_NUMBER2 }}:{{ PORT_NUMBER2 }}/tcp
      - {{ PORT_NUMBER3 }}:{{ PORT_NUMBER3 }}/tcp
    volumes:
      - /opt/stacks/{{ APP }}/config/{{ APP }}.yaml:/etc/{{ APP }}.yaml:ro
      - {{ APP }}-data:/var/{{ APP }}:rw
      - /etc/localtime:/etc/localtime:ro
    networks:
      - {{ NETWORK }}

volumes:
  {{ APP }}-data:
    external: true

networks:
  {{ NETWORK }}:
    external: true