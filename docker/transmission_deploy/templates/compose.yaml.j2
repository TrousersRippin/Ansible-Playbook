---
services:
  {{ APP }}:
    image: {{ IMAGE_NAME }}:{{ IMAGE_TAG }}
    container_name: {{ APP }}
    hostname: {{ APP }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - TZ=Europe/Stockholm
      - PUID=1000
      - PGID=1000
    ports:
      - {{ PORT_NUMBER1 }}:9091/tcp
      - {{ PORT_NUMBER2 }}:51413/tcp
      - {{ PORT_NUMBER2 }}:51413/udp
    volumes:
      - /home/{{ USER }}/containers/storage/{{ APP }}/config:/config:rw
      - /home/{{ USER }}/containers/storage/{{ APP }}/config:/watch:rw
      - /etc/localtime:/etc/localtime:ro
    networks:
      - {{ NETWORK }}
    labels:
      - com.centurylinklabs.watchtower.enable=true
      - logging=promtail
      - logging_jobname=containerlogs

networks:
  {{ NETWORK }}:
    external: true